DATABASE_URL=postgres://user:password@host:port/dbname
NODE_ENV=development
PORT=3000
MCP_API_KEY=your-super-secret-key
# Optional: per-statement timeout in milliseconds (default 30000)
STATEMENT_TIMEOUT_MS=30000
# Optional: when "true", logs SSE session lifecycle. Tool inputs are NEVER logged.
LOG_QUERIES=false
